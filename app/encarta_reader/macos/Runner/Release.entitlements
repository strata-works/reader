<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Sandbox disabled: reads a configurable corpus directory anywhere on
	     disk. Local restoration showcase, not an App Store target (spec §1). -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
</dict>
</plist>
